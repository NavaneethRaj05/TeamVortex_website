# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# ── API ───────────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5001
# Production: REACT_APP_API_URL=https://api.teamvortex.in

# ── Payment Gateway (informational — actual keys live in server/.env) ─────────
# These are only needed if you want to show gateway branding in the UI
REACT_APP_PAYMENT_GATEWAY=razorpay
# Options: razorpay | cashfree
